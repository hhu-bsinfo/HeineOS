{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/loader/kernel.elf",
            "cwd": "${workspaceFolder}",
            "miDebuggerPath": "rust-gdb",
            "miDebuggerServerAddress": "localhost:1234",
            "stopAtEntry": false,
            "setupCommands": [
                { "text": "-enable-pretty-printing" },
                { "text": "set disassembly-flavor intel"},
                { "text": "set output-radix 16" }
            ],
            "preLaunchTask": "debug"
        }
    ]
}